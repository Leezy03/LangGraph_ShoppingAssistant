# ========== LLM 配置 ==========
# 模型名称（示例：deepseek-chat, gpt-4o-mini 等）
LLM_MODEL_ID=deepseek-chat

# 模型 API Key
LLM_API_KEY=

# 模型服务地址
LLM_BASE_URL=https://api.deepseek.com

# 可选：请求超时（秒）
LLM_TIMEOUT=60

# ========== 搜索配置 ==========
# Brave Search API Key（购物测评搜索必需）
SEARCH_API_KEY=

# ========== 服务配置 ==========
HOST=0.0.0.0
PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

# 多个域名用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
